NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오톡·SNS 링크 미리보기용 (og:image 절대 URL) — 프로덕션 URL 필수
NEXT_PUBLIC_SITE_URL=https://allbarreun-edu.vercel.app

# Server-only: student account creation, password reset (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only: 학생부 분석 (OpenAI — never expose to client)
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: 미설정 시 gpt-5.5 → 실패 시 gpt-5
OPENAI_MODEL_STUDENT_RECORDS=gpt-5.5
# Optional: OCR 모델 — Vision 전사는 gpt-4o 권장 (미설정 시 gpt-4o → gpt-4.1 → gpt-4o-mini)
OPENAI_MODEL_STUDENT_RECORDS_OCR=gpt-4o

# Client: Kakao JavaScript SDK (학생부 분석·리포트 카카오톡 공유)
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
